# =========================
# 强制统一使用 LF
# =========================

# 默认所有文本文件统一 LF
* text=auto eol=lf

# 常见源码
*.c   text eol=lf
*.cc  text eol=lf
*.cpp text eol=lf
*.h   text eol=lf
*.hpp text eol=lf

# 文档
*.md   text eol=lf
*.txt  text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# CMake
CMakeLists.txt text eol=lf
*.cmake text eol=lf

# shell 脚本（非常重要！避免 ^M 报错）
*.sh text eol=lf

# Windows 脚本保留 CRLF（可选）
*.bat text eol=crlf
*.cmd text eol=crlf

# 二进制文件禁止换行处理
*.png binary
*.jpg binary
*.zip binary
*.pdf binary
