# Compose 项目标识，用于隔离命名卷和容器名。
COMPOSE_PROJECT_NAME=smt-pilot

# 对外只暴露 Nginx；MySQL/Redis 端口只由 compose.dev.yaml 可选开放到回环地址。
SMT_DATASTREAM_PORT=9090
SMT_LOGTRACE_PORT=9091
SMT_MYSQL_PORT=3306
SMT_REDIS_PORT=6379

# 未指定时使用仓库内仅供本机联调的示例 Secret。生产必须改为受控目录。
SMT_SECRET_DIR=./secrets/example
SMT_BACKUP_ROOT=./backups
SMT_RELEASE_VERSION=dev
SMT_APPLY_DEV_SEED=1

# 单机试点资源上限，需按真实三线节拍和宿主机容量重新校准。
SMT_DATASTREAM_CPUS=2.0
SMT_DATASTREAM_MEMORY=2g
SMT_LOGSEARCH_CPUS=3.0
SMT_LOGSEARCH_MEMORY=4g
SMT_GATEWAY_CPUS=1.0
SMT_GATEWAY_MEMORY=512m
